# ==========================================
# Game Server Manager — Environment Variables
# ==========================================
# Copy to .env and fill in values as needed.
# .env is gitignored — never commit real secrets.
#
# Note: Each service runs separately and reads PORT from its own
# environment (defaults shown below). Override only if you need
# non-default ports.

# Control Plane API (default 8080)
# API_PORT=8080

# Control Plane Web (default 3000)
# WEB_PORT=3000

# Discord Control Bot (required for bot)
# DISCORD_TOKEN=your_discord_bot_token_here
