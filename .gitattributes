# Normalize all text files to LF on commit.
# Git auto-detects text vs binary and handles conversion
# on checkout based on the user's platform.
* text=auto

# Explicit LF for code and config — these must never be CRLF in the repo
*.go        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
*.sh        text eol=lf
Dockerfile  text eol=lf
.editorconfig text eol=lf
.gitattributes text eol=lf
.gitignore  text eol=lf

# Binary files — never touch these
*.exe       -text
*.dll       -text
*.so        -text
*.dylib     -text
*.png       -text
*.jpg       -text
*.jpeg      -text
*.gif       -text
*.ico       -text
